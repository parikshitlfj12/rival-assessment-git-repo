# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/rival_assessment

# Secret for signing session cookies / JWT (min 32 random chars)
SESSION_SECRET=change-me-to-a-long-random-string-at-least-32-chars

# Node environment
NODE_ENV=development

# Optional: public app URL for production cookies/CORS
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Comma-separated emails that receive the admin role on signup/login
ADMIN_EMAILS=you@example.com
